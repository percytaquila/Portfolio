---
// src/components/layout/Header.astro
const navLinks = [
  { href: "/",          label: "Home"       },
  { href: "/portfolio", label: "Portafolio" },
  { href: "/security",  label: "Seguridad"  },
  { href: "/writeups",  label: "Writeups"   },
];
const current = Astro.url.pathname;
---

<header>
  <nav>
    <a href="/" class="nav-logo"><span>~/</span>dev·sec</a>

    <ul class="nav-links" id="nav-menu">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[{ active: current === link.href || (link.href !== "/" && current.startsWith(link.href)) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const menu      = document.getElementById('nav-menu');

  function toggleMenu(open) {
    hamburger?.classList.toggle('open', open);
    menu?.classList.toggle('open', open);
    hamburger?.setAttribute('aria-expanded', String(open));
  }

  hamburger?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleMenu(!menu?.classList.contains('open'));
  });

  document.addEventListener('click', (e) => {
    if (menu?.classList.contains('open') && !menu.contains(e.target) && !hamburger?.contains(e.target)) {
      toggleMenu(false);
    }
  });

  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => toggleMenu(false)));
</script>

<style>
  header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: 60px;
    background: rgba(15, 17, 23, 0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    max-width: 1280px; margin: 0 auto; height: 100%;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 2rem;
  }

  .nav-logo {
    font-family: var(--font-mono); font-size: .85rem; font-weight: 700;
    color: var(--text); text-decoration: none; z-index: 101;
  }
  .nav-logo span { color: var(--blue2); }

  .nav-links {
    display: flex; gap: .2rem; list-style: none; margin: 0; padding: 0;
  }
  .nav-links a {
    font-size: .8rem; font-weight: 500; color: var(--text2);
    text-decoration: none; padding: .35rem .85rem; border-radius: 6px; transition: all .15s;
  }
  .nav-links a:hover  { color: var(--text); background: rgba(59,91,219,.12); }
  .nav-links a.active { color: var(--blue3); background: rgba(59,91,219,.12); }

  .nav-cta {
    font-size: .78rem; font-weight: 600; color: #fff;
    background: var(--blue); padding: .42rem 1.1rem; border-radius: 7px;
    text-decoration: none; transition: background .15s;
  }
  .nav-cta:hover { background: var(--blue2); }

  .mobile-cta { display: none; }

  .hamburger {
    display: none; flex-direction: column; justify-content: space-between;
    width: 24px; height: 18px; background: none; border: none; cursor: pointer;
    padding: 0; z-index: 101;
  }
  .hamburger span {
    display: block; width: 100%; height: 2px;
    background: var(--text); border-radius: 2px; transition: all .25s;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .mobile-cta { display: block; }

    .nav-links {
      position: fixed;
      top: 70px;
      right: 1rem;
      width: min(280px, calc(100vw - 2rem));
      margin: 0;
      padding: .6rem;
      flex-direction: column;
      gap: .2rem;
      list-style: none;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: 0 12px 40px rgba(0,0,0,.45), 0 0 0 1px rgba(255,255,255,.04);
      z-index: 99;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-8px) scale(.98);
      transform-origin: top right;
      transition: opacity .2s ease, transform .2s ease;
    }

    .nav-links.open {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }

    .nav-links li { width: 100%; }

    .nav-links a {
      display: block; width: 100%;
      font-size: .88rem; padding: .7rem .9rem;
      border-radius: 8px; color: var(--text2); box-sizing: border-box;
    }
    .nav-links a:hover  { background: rgba(59,91,219,.1); color: var(--text); }
    .nav-links a.active { background: rgba(59,91,219,.12); color: var(--blue3); }

    .mobile-cta {
      margin-top: .3rem;
      padding-top: .5rem;
      border-top: 1px solid var(--border);
    }
    .mobile-cta .nav-cta {
      display: block; text-align: center;
      padding: .65rem; border-radius: 8px;
      color: #fff; background: var(--blue);
    }
    .mobile-cta .nav-cta:hover { background: var(--blue2); }
  }
</style>