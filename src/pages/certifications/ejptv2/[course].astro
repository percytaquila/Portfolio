---
// src/pages/certifications/ejptv2/[course].astro
// Renderiza cualquier .mdx de src/content/certifications/ejptv2/
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header     from '@/components/layout/Header.astro';
import Footer     from '@/components/layout/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const courses = await getCollection('certifications');
  return courses.map(entry => ({
    params: { course: entry.slug.split('/').pop() },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const statusIcon = { done: '✓', wip: '→', next: '○' };
const statusColor = { done: 'var(--green)', wip: 'var(--yellow)', next: 'var(--text3)' };
---

<BaseLayout title={`${d.title} — ${d.academy} | Percy Taquila`}>
  <Header />

  <main style="padding-top: 60px; flex:1; display:flex; flex-direction:column;">
    <div class="course-page">

      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <a href="/security">Seguridad</a>
        <span>›</span>
        <a href="/security#cert-ejptv2">{d.cert?.toUpperCase()}</a>
        <span>›</span>
        <span>{d.title}</span>
      </div>

      <div class="course-layout">

        <!-- ── Sidebar ── -->
        <aside class="course-sidebar">
          <div class="sidebar-card">
            <div class="cs-academy">{d.academy}</div>
            <div class="cs-title">{d.title}</div>

            <div class="cs-meta-list">
              <div class="cs-meta-item">
                <span class="cs-meta-label">Instructor</span>
                <span class="cs-meta-value">{d.instructor}</span>
              </div>
              <div class="cs-meta-item">
                <span class="cs-meta-label">Duración</span>
                <span class="cs-meta-value">{d.duration}</span>
              </div>
              <div class="cs-meta-item">
                <span class="cs-meta-label">Estado</span>
                <span class="cs-meta-value status-done">✓ Completado</span>
              </div>
              {d.rating && (
                <div class="cs-meta-item">
                  <span class="cs-meta-label">Rating</span>
                  <span class="cs-meta-value">{'⭐'.repeat(d.rating)}</span>
                </div>
              )}
            </div>

            {d.url && (
              <a href={d.url} target="_blank" rel="noopener" class="cs-link">
                Ver curso →
              </a>
            )}
          </div>

          <!-- Temario sidebar -->
          {d.modules && (
            <div class="sidebar-card">
              <div class="sidebar-label">Temario</div>
              <div class="mod-list">
                {d.modules.map((m: any) => (
                  <div class="mod-row">
                    <span class="mod-n">{m.num}</span>
                    <span class="mod-name">{m.title}</span>
                    <span style={`font-size:.7rem; font-weight:600; color:${statusColor[m.status as keyof typeof statusColor]}`}>
                      {statusIcon[m.status as keyof typeof statusIcon]}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </aside>

        <!-- ── Content ── -->
        <article class="course-content prose">
          <Content />
        </article>

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .course-page {
    max-width: 1100px; margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 4vw, 2rem) 5rem;
    flex: 1;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex; align-items: center; gap: .5rem;
    font-size: .72rem; color: var(--text3); margin-bottom: 1.8rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--blue3); transition: color .15s; }
  .breadcrumb a:hover { color: var(--text); }
  .breadcrumb span { color: var(--text3); }

  /* Layout */
  .course-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* Sidebar */
  .course-sidebar { display: flex; flex-direction: column; gap: 1rem; position: sticky; top: 80px; }

  .sidebar-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 12px; padding: 1.4rem;
  }
  .sidebar-label {
    font-size: .6rem; font-weight: 600; color: var(--text3);
    text-transform: uppercase; letter-spacing: .1em; margin-bottom: .8rem;
  }
  .cs-academy { font-size: .65rem; font-weight: 600; color: var(--blue3); text-transform: uppercase; letter-spacing: .08em; margin-bottom: .3rem; }
  .cs-title   { font-size: .95rem; font-weight: 700; margin-bottom: 1.2rem; line-height: 1.3; }

  .cs-meta-list  { display: flex; flex-direction: column; gap: .6rem; margin-bottom: 1.2rem; }
  .cs-meta-item  { display: flex; flex-direction: column; gap: .1rem; }
  .cs-meta-label { font-size: .6rem; color: var(--text3); text-transform: uppercase; letter-spacing: .07em; }
  .cs-meta-value { font-size: .8rem; color: var(--text); }
  .status-done   { color: var(--green); font-weight: 600; }

  .cs-link {
    display: block; text-align: center; font-size: .75rem; font-weight: 600;
    color: var(--text); background: var(--blue); border-radius: 7px;
    padding: .55rem; text-decoration: none; transition: background .15s;
  }
  .cs-link:hover { background: var(--blue2); }

  .mod-list { display: flex; flex-direction: column; gap: .25rem; }
  .mod-row  {
    display: flex; align-items: center; gap: .5rem;
    padding: .32rem .4rem; border-radius: 5px; transition: background .12s;
  }
  .mod-row:hover { background: var(--bg3); }
  .mod-n    { font-family: var(--font-mono); font-size: .58rem; color: var(--text3); width: 20px; flex-shrink: 0; }
  .mod-name { font-size: .72rem; color: var(--text2); flex: 1; line-height: 1.4; }

  /* Content */
  .course-content { min-width: 0; }

  /* Responsive */
  @media (max-width: 768px) {
    .course-layout { grid-template-columns: 1fr; }
    .course-sidebar { position: static; }
  }
</style>
