---
// src/pages/certifications/ejptv2/[course]/[module].astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header     from '@/components/layout/Header.astro';
import Footer     from '@/components/layout/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('certifications');
  console.log('All IDs:', entries.map(e => e.id));

  return entries
    .filter(entry => entry.id.split('/').length === 3) // ejptv2/curso-mario/01-xxx
    .map(entry => {
      const parts  = entry.id.split('/');
      const course = parts[1]; // curso-mario
      const module = parts[2]; // 01-Preparacion-laboratorios
      return {
        params: { course, module },
        props:  { entry, allEntries: entries },
      };
    });
}

const { entry, allEntries } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const parts      = entry.id.split('/');
const courseSlug = parts[1];
const moduleSlug = parts[2];

// Todos los módulos del mismo curso, ordenados
const siblings = allEntries
  .filter(e => e.id.startsWith(`ejptv2/${courseSlug}/`))
  .sort((a, b) => a.id.localeCompare(b.id));

const currentIdx = siblings.findIndex(e => e.id === entry.id);
const prev = siblings[currentIdx - 1] ?? null;
const next = siblings[currentIdx + 1] ?? null;

const statusIcon  = { done: '✓', wip: '→', next: '○' };
const statusColor = { done: 'var(--green)', wip: 'var(--yellow)', next: 'var(--text3)' };
---

<BaseLayout title={`${d.title} | Percy Taquila`}>
  <Header />

  <main style="padding-top: 60px; flex:1; display:flex; flex-direction:column;">
    <div class="course-page">

      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <a href="/security">Seguridad</a>
        <span>›</span>
        <a href="/security">{d.cert?.toUpperCase() ?? 'eJPTv2'}</a>
        <span>›</span>
        <span class="bc-course">{courseSlug.replace(/-/g, ' ')}</span>
        <span>›</span>
        <span>{d.title}</span>
      </div>

      <div class="course-layout">

        <!-- ── Sidebar ── -->
        <aside class="course-sidebar">
          <div class="sidebar-card">
            <div class="sidebar-label">Módulos</div>
            <div class="mod-list">
              {siblings.map((s) => (
                <a
                  href={`/certifications/ejptv2/${courseSlug}/${s.id.split('/').pop()}`}
                  class:list={['mod-row', { active: s.id === entry.id }]}
                >
                  <span class="mod-n">{s.data.num ?? s.id.split('/').pop()?.slice(0,2)}</span>
                  <span class="mod-name">{s.data.title}</span>
                  {s.data.status && (
                    <span style={`font-size:.65rem;font-weight:600;color:${statusColor[s.data.status as keyof typeof statusColor]}`}>
                      {statusIcon[s.data.status as keyof typeof statusIcon]}
                    </span>
                  )}
                </a>
              ))}
            </div>
          </div>
        </aside>

        <!-- ── Content ── -->
        <div class="content-col">
          <article class="course-content prose">
            <Content />
          </article>

          <!-- Navegación anterior / siguiente -->
          <nav class="module-nav">
            {prev ? (
              <a href={`/certifications/ejptv2/${courseSlug}/${prev.id.split('/').pop()}`} class="nav-btn nav-prev">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="10,3 5,8 10,13"/></svg>
                <div>
                  <div class="nav-label">Anterior</div>
                  <div class="nav-title">{prev.data.title}</div>
                </div>
              </a>
            ) : <div />}

            {next ? (
              <a href={`/certifications/ejptv2/${courseSlug}/${next.id.split('/').pop()}`} class="nav-btn nav-next">
                <div>
                  <div class="nav-label">Siguiente</div>
                  <div class="nav-title">{next.data.title}</div>
                </div>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6,3 11,8 6,13"/></svg>
              </a>
            ) : <div />}
          </nav>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .course-page {
    max-width: 1200px; margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 4vw, 2rem) 5rem;
    flex: 1;
  }

  .breadcrumb {
    display: flex; align-items: center; gap: .5rem;
    font-size: .72rem; color: var(--text3); margin-bottom: 1.8rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--blue3); text-decoration: none; transition: color .15s; }
  .breadcrumb a:hover { color: var(--text); }
  .bc-course { text-transform: capitalize; }

  .course-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* Sidebar */
  .course-sidebar { position: sticky; top: 80px; }

  .sidebar-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 12px; padding: 1.2rem;
  }
  .sidebar-label {
    font-size: .58rem; font-weight: 600; color: var(--text3);
    text-transform: uppercase; letter-spacing: .1em; margin-bottom: .75rem;
  }

  .mod-list { display: flex; flex-direction: column; gap: .15rem; }
  .mod-row  {
    display: flex; align-items: center; gap: .5rem;
    padding: .4rem .5rem; border-radius: 6px;
    text-decoration: none; transition: background .12s;
    color: var(--text2);
  }
  .mod-row:hover  { background: var(--bg3); color: var(--text); }
  .mod-row.active { background: rgba(59,91,219,.12); color: var(--blue3); }
  .mod-n    { font-family: var(--font-mono); font-size: .58rem; color: var(--text3); width: 20px; flex-shrink: 0; }
  .mod-name { font-size: .72rem; flex: 1; line-height: 1.4; }

  /* Content */
  .content-col  { min-width: 0; display: flex; flex-direction: column; gap: 2rem; }
  .course-content { min-width: 0; }

  /* Prose */
  :global(.prose h1) { font-size: 1.5rem; font-weight: 700; padding-bottom: .6rem; border-bottom: 1px solid var(--border); margin-bottom: 1.5rem; color: var(--text); }
  :global(.prose h2) { font-size: 1.1rem; font-weight: 700; padding-bottom: .45rem; border-bottom: 1px solid var(--border); margin-top: 2rem; margin-bottom: .75rem; color: var(--text); }
  :global(.prose h3) { font-size: .95rem; font-weight: 600; margin-top: 1.4rem; margin-bottom: .5rem; color: var(--text2); }
  :global(.prose p)  { font-size: .85rem; color: var(--text2); line-height: 1.8; margin-bottom: .9rem; }
  :global(.prose ul) { padding-left: 1.2rem; margin-bottom: .9rem; }
  :global(.prose li) { font-size: .85rem; color: var(--text2); line-height: 1.7; margin-bottom: .25rem; }
  :global(.prose strong) { color: var(--text); font-weight: 600; }
  :global(.prose a)  { color: var(--blue3); text-decoration: underline; }
  :global(.prose pre) { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 1rem; overflow-x: auto; margin-bottom: 1rem; }
  :global(.prose code) { font-family: var(--font-mono); font-size: .78rem; color: var(--blue3); }
  :global(.prose pre code) { color: var(--text2); }
  :global(.prose table) { width: 100%; border-collapse: collapse; font-size: .8rem; margin-bottom: 1rem; }
  :global(.prose th) { background: var(--bg3); color: var(--text); padding: .5rem .75rem; text-align: left; border: 1px solid var(--border); }
  :global(.prose td) { padding: .45rem .75rem; border: 1px solid var(--border); color: var(--text2); }
  :global(.prose blockquote) { border-left: 3px solid var(--blue); padding-left: 1rem; color: var(--text3); font-style: italic; margin: 1rem 0; }

  /* Nav anterior/siguiente */
  .module-nav {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1rem; padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .nav-btn {
    display: flex; align-items: center; gap: .75rem;
    padding: .9rem 1.1rem; background: var(--bg2);
    border: 1px solid var(--border); border-radius: 10px;
    text-decoration: none; color: var(--text2);
    transition: all .15s;
  }
  .nav-btn:hover { border-color: rgba(59,91,219,.4); color: var(--text); background: var(--bg3); }
  .nav-next { justify-content: flex-end; text-align: right; }
  .nav-label { font-size: .58rem; color: var(--text3); text-transform: uppercase; letter-spacing: .08em; margin-bottom: .2rem; }
  .nav-title { font-size: .78rem; font-weight: 600; }

  @media (max-width: 768px) {
    .course-layout { grid-template-columns: 1fr; }
    .course-sidebar { position: static; }
    .module-nav { grid-template-columns: 1fr; }
  }
</style>